# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# scripts locaux (création admin, etc.)
scripts/create-admin-user.js

# outils locaux (CLI, binaires)
/tools/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Cursor / IDE
.cursor/

# Playwright / tests artefacts
/playwright-report/
/test-results/

# Supabase CLI state (local, non committable)
/supabase/.temp/
/supabase/.branches/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

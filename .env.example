# --- Supabase (obligatoire en dev/prod) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optionnel mais recommandé pour les Server Actions MJ/admin sécurisées
# SUPABASE_SERVICE_ROLE_KEY=

# --- Routes cron sécurisées (API) ---
# CRON_SECRET=

# --- Debug carte (logs NDJSON dans debug-5b6b8a.log via POST /api/debug-map-session) ---
# next dev : activé sans variable. next start / prod:local : mettre DEBUG_MAP_SESSION=1 ou utiliser npm run prod:local:debug
# DEBUG_MAP_SESSION=1

# --- Carte : rendu (défaut dans le code = WebGL + rollout all ; pas besoin de variables pour ça) ---
# Variables optionnelles = surcharge au build (rollback d’urgence, canary, tests locaux).
# Test local MJ seulement : npm run dev:webgl:mj
# Forcer le SVG partout (kill-switch) :
# NEXT_PUBLIC_MAP_RENDERER=svg
# NEXT_PUBLIC_MAP_RENDERER_ROLLOUT=off

# Rollout (surcharge) : off | mj-only | public-canary | all — défaut code = all
# - off : SVG partout
# - mj-only : WebGL sur /mj/carte si renderer=webgl, public reste SVG
# - public-canary : MJ en WebGL ; public WebGL pour % utilisateurs (clé stable localStorage)
# - all : WebGL partout si renderer=webgl
# NEXT_PUBLIC_MAP_RENDERER_ROLLOUT=mj-only

# Pourcentage de canary public (0–100), si rollout=public-canary
# NEXT_PUBLIC_MAP_RENDERER_CANARY_PCT=5

# Kill-switch immédiat : repasse tout en SVG
# NEXT_PUBLIC_MAP_RENDERER_FORCE_SVG=1

# --- Carte : feature flags UI ---
# NEXT_PUBLIC_REALM_COLORING_V2=1
# NEXT_PUBLIC_MAP_INFO_PANELS_V2=1
# NEXT_PUBLIC_ROLE_MODEL_V2=1
# NEXT_PUBLIC_MAP_ROUTE_WORKER=1
# NEXT_PUBLIC_MAP_QUALITY_TIER=perf
# NEXT_PUBLIC_MAP_MOBILE_HARD_MODE=1
# NEXT_PUBLIC_MAP_ZERO_SVG_SPIKE=0

# --- Carte : debug performance (laisser à 0 en prod) ---
# NEXT_PUBLIC_MAP_DEBUG_METRICS=0
# NEXT_PUBLIC_MAP_DEBUG_FRAME_GAP=0

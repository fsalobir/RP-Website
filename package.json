{
  "name": "rp-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fast": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev",
    "dev:watch": "node scripts/dev-with-restart.js",
    "test:prod": "next build && next start",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "supabase": "node scripts/run-supabase.mjs",
    "supabase:functions:serve:process-due": "node scripts/run-supabase.mjs functions serve process-ai-events-due --no-verify-jwt",
    "test:e2e:setup": "npm run supabase -- start && npm run supabase -- db reset --local",
    "test:e2e:run": "npm run e2e",
    "check:edge": "node scripts/check-edge-functions.mjs",
    "sync:edge-shared": "node scripts/sync-edge-shared.mjs",
    "seed:map-regions": "node --env-file=.env.local scripts/seed-map-regions.js",
    "generate:orphan-regions": "node scripts/generate-fill-orphan-regions.js",
    "test:process-due-parity": "node --env-file=.env.local scripts/process-due-parity-check.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "d3-geo": "^3.1.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-simple-maps": "^3.0.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
